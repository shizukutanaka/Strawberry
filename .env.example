# Strawberry 環境変数サンプル
# 本番環境では JWT_SECRET / ENCRYPTION_KEY / SESSION_SECRET は必須。
# 未設定の場合、本番(NODE_ENV=production)では起動に失敗します(fail-fast)。
# 開発時に未設定なら、プロセス起動ごとにランダムな一時シークレットが生成されます。

# 実行環境
NODE_ENV=development
PORT=3000
HOST=localhost
API_PREFIX=/api/v1
# カンマ区切り。'*' は全許可(本番非推奨)
CORS_ORIGINS=*

# --- セキュリティ（必須シークレット。16文字以上を推奨）---
JWT_SECRET=
JWT_EXPIRES_IN=24h
ENCRYPTION_KEY=
SESSION_SECRET=
# マシン間通信用APIキー（任意。設定時のみ x-api-key 認証が有効）
API_KEY=
BCRYPT_ROUNDS=12

# --- Google OAuth（マスター3重認証。未設定なら /master-auth/google は503）---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MASTER_GOOGLE_EMAIL=
MASTER_TOTP_SECRET=

# --- Lightning Network / Bitcoin ---
BITCOIN_NETWORK=testnet
LND_HOST=127.0.0.1:10009
LND_CERT_PATH=
LND_MACAROON_PATH=
# 運営手数料率（例: 0.015 = 1.5%）
BTC_FEE_RATE=0.015

# --- ログ ---
LOG_LEVEL=info

# --- 外部通知（任意）---
SLACK_WEBHOOK=
DISCORD_WEBHOOK=
LINE_TOKEN=
SENTRY_DSN=

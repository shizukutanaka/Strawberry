    "feedback-report": "node scripts/feedback-report.js",
    "feedback-to-checklist": "node scripts/feedback-to-checklist.js",
    "slack-notify": "node scripts/slack-notify.js",
    "feedback-to-sheets": "node scripts/feedback-to-sheets.js",
    "feedback-priority": "node scripts/feedback-priority.js",
    "priority-to-sheets": "node scripts/priority-to-sheets.js",
    "progress-report": "node scripts/progress-report.js",
    "kpi-trend-graph": "node scripts/kpi-trend-graph.js",
    "priority-to-notion": "node scripts/priority-to-notion.js",
    "notion-progress-report": "node scripts/notion-progress-report.js",
    "slack-notify-notion": "node scripts/slack-notify-notion.js",
    "checklist-to-issues": "node scripts/checklist-to-issues.js",
    "checklist-kpi-report": "node scripts/checklist-kpi-report.js",
    "slack-notify-checklist-kpi": "node scripts/slack-notify-checklist-kpi.js",
    "slack-notify-graph": "node scripts/slack-notify-graph.js",
    "alert-high-priority": "node scripts/alert-high-priority.js",
    "assignee-progress-report": "node scripts/assignee-progress-report.js",
    "alert-overdue": "node scripts/alert-overdue.js",
    "alert-overdue-high": "node scripts/alert-overdue-high.js",
    "alert-kpi-trend": "node scripts/alert-kpi-trend.js",
    "prisma": "prisma",
    "prisma-generate": "prisma generate",
    "prisma-migrate": "prisma migrate dev --name init",
    "prisma-studio": "prisma studio",
    "gpu-failure-monitor": "node scripts/gpu-failure-monitor.js",
    "setup": "npm ci && npm run prisma-migrate && npm run openapi-gen && npm test"

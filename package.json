    "express-session": "^1.18.0",
    "graphql": "^16.9.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "joi-to-swagger": "^6.2.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^10.2.1",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.14",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "prom-client": "^15.1.0",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0"
